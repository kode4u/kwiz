# Environment Configuration
# This file contains environment variables for docker-compose

# Database Configuration
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=moodle
MYSQL_USER=moodle
MYSQL_PASSWORD=moodlepass

# Moodle Configuration
MOODLE_URL=http://localhost:8080
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=Admin@123
MOODLE_ADMIN_EMAIL=admin@example.com

# Redis Configuration
REDIS_PASSWORD=

# WebSocket Server Configuration
WS_PORT=3001
WS_SECRET=change-me-in-production-use-strong-random-key
CORS_ORIGIN=http://localhost:8080

# LLM API Configuration
LLM_API_PORT=5001
# LLM_BACKEND=openai
# OPENAI_API_KEY=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
MAX_QUESTIONS=10
DEFAULT_LANGUAGE=en

# JWT Configuration
JWT_SECRET=change-me-in-production-use-strong-random-key
JWT_EXPIRY=3600

# Development/Production Mode
NODE_ENV=development

LLM_BACKEND=local
LOCAL_LLM_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:8b

# Comma-separated list of Ollama models to auto-download
OLLAMA_PRELOAD_MODELS=deepseek-r1:8b,llama3.2:3b,codegemma:latest