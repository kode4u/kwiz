###############################################
### Error Cases
###############################################

### Missing Required Field (topic)
POST {{baseUrl}}/generate
Content-Type: {{contentType}}

{
  "level": "medium",
  "n_questions": 1
}

### Invalid Difficulty Level
POST {{baseUrl}}/generate
Content-Type: {{contentType}}

{
  "topic": "Test topic",
  "level": "invalid",
  "n_questions": 1
}

### Exceeding Max Questions
POST {{baseUrl}}/generate
Content-Type: {{contentType}}

{
  "topic": "Test topic",
  "level": "medium",
  "n_questions": 20
}

### Invalid Backend
POST {{baseUrl}}/generate
Content-Type: {{contentType}}

{
  "topic": "Test topic",
  "level": "medium",
  "n_questions": 1,
  "backend": "invalid_backend"
}

