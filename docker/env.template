# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# Moodle Configuration
# ============================================
MOODLE_URL=http://localhost:8080
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=Admin@123
MOODLE_ADMIN_EMAIL=admin@example.com

# ============================================
# Database Configuration
# ============================================
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=moodle
MYSQL_USER=moodle
MYSQL_PASSWORD=moodlepass

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=

# ============================================
# WebSocket Server Configuration
# ============================================
WS_PORT=3001
WS_SECRET=change-me-in-production-use-strong-random-key
CORS_ORIGIN=http://localhost:8080

# ============================================
# LLM API Configuration
# ============================================
LLM_API_PORT=5001
LLM_BACKEND=openai
OPENAI_API_KEY=your-openai-api-key-here
MAX_QUESTIONS=10
DEFAULT_LANGUAGE=en

# Local LLM (Ollama) - use when LLM_BACKEND=local
# Ollama must be running ON YOUR HOST (not in Docker). Install: https://ollama.ai
# The llmapi container reaches it via host.docker.internal (Mac/Windows/Linux with extra_hosts).
LOCAL_LLM_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-coder:latest

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: This must match the JWT_SECRET in Moodle plugin settings
JWT_SECRET=change-me-in-production-use-strong-random-key
JWT_EXPIRY=3600

# ============================================
# Development/Production Mode
# ============================================
NODE_ENV=development

# ============================================
# Notes
# ============================================
# 1. Generate strong secrets: openssl rand -hex 32
# 2. Never commit .env files to version control
# 3. Use different values for production
# 4. JWT_SECRET must match in Moodle plugin settings

